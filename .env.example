# AIF Review — API Keys
# Set the keys for the providers you want to use.
# You only need ONE key to get started. More models = better cross-validation.
#
# ┌─────────────────────────────────────────────────────────────────┐
# │  FREE TIER (no credit card required)                           │
# │                                                                │
# │  Groq       → console.groq.com/keys           (fastest)       │
# │  Cerebras   → cloud.cerebras.ai                (1M tok/day)   │
# │  Mistral    → console.mistral.ai               (500K TPM)     │
# │  Gemini     → aistudio.google.com/apikey        (250K TPM)    │
# │  OpenRouter → openrouter.ai/settings/keys       (free models) │
# │                                                                │
# │  PAID                                                          │
# │                                                                │
# │  Anthropic  → console.anthropic.com/settings/keys              │
# │  OpenAI     → platform.openai.com/api-keys                    │
# └─────────────────────────────────────────────────────────────────┘

# Free providers (recommended — start here)
GROQ_API_KEY=
CEREBRAS_API_KEY=
MISTRAL_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# Paid providers (optional — higher quality)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
